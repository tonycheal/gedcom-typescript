{
  "name": "gedcom-typescript",
  "version": "0.1.0",
  "description": "Read and write GEDCOM 5.5.5 files with fully typed TypeScript objects",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gedcom",
    "genealogy",
    "family-tree",
    "parser",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tonycheal/gedcom-typescript.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
